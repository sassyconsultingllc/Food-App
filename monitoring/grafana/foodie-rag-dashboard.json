      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "interval": null,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"expr": "sum(rate(ragg_job_processed_total[5m]))", "format": "time_series", "instant": false}
      ],
      "title": "RAG Jobs Processed (rate)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "interval": null,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"expr": "sum(rate(ragg_job_failed_total[5m]))", "format": "time_series", "instant": false}
      ],
      "title": "RAG Jobs Failed (rate)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "interval": null,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {
          "expr": "(sum(rate(ragg_job_failed_total[5m])) / sum(rate(ragg_job_processed_total[5m]))) * 100",
          "format": "time_series",
          "instant": false
        }
      ],
      "title": "Failure Rate (%)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "interval": null,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(ragg_job_duration_seconds_bucket[5m])) by (le))",
          "format": "time_series",
          "instant": false
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(ragg_job_duration_seconds_bucket[5m])) by (le))",
          "format": "time_series",
          "instant": false
        }
      ],
      "title": "Job Latency (P95 / P50 seconds)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 14},
      "id": 6,
      "interval": null,
      "targets": [
        {"expr": "ragg_queue_length{queue=\"reindex\"}", "format": "time_series", "instant": false}
      ],
      "title": "Queue Length (reindex)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 14},
      "id": 7,
      "interval": null,
      "options": {},
      "targets": [
        {
          "expr": "topk(20, sum by (job) (increase(ragg_job_processed_total[1h])))",
          "format": "table",
          "instant": false
        }
      ],
      "title": "Top Jobs (processed in last hour)",
      "type": "table"
    },
