{
  "name": "foodie-finder",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 npx expo start --web --port 8082",
    "dev:services": "docker-compose up -d",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:protected": "node scripts/build-protected.js --profile=production",
    "build:protected:dev": "node scripts/build-protected.js --profile=development",
    "start": "NODE_ENV=production node dist/index.js",
    "start:protected": "NODE_ENV=production node dist/protected/index.js",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs",
    "worker:dev": "wrangler dev worker/index.ts",
    "worker:deploy": "wrangler deploy --env=\"\"",
    "worker:deploy:prod": "wrangler deploy --env=production",
    "worker:tail": "wrangler tail",
    "worker:secrets": "echo 'Run: wrangler secret put GOOGLE_PLACES_API_KEY && wrangler secret put FOURSQUARE_API_KEY && wrangler secret put HERE_API_KEY'",
    "d1:init": "wrangler d1 execute foodie-finder --file=./worker/schema.sql",
    "d1:studio": "wrangler d1 studio foodie-finder"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "dependencies": {
    "@bull-board/api": "^6.18.0",
    "@bull-board/express": "^6.18.0",
    "@expo/vector-icons": "^15.0.3",
    "@langchain/community": "^1.1.15",
    "@langchain/core": "^1.1.24",
    "@langchain/openai": "^1.2.7",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.5",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "11.10.0",
    "@trpc/react-query": "11.10.0",
    "@trpc/server": "11.10.0",
    "axios": "^1.13.5",
    "bullmq": "^5.69.1",
    "chromadb": "^3.3.0",
    "cookie": "^1.1.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.10",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "^19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "^14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.2.1",
    "ioredis": "^5.9.3",
    "jose": "6.1.3",
    "langchain": "^1.2.24",
    "mysql2": "^3.17.1",
    "prom-client": "^15.1.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.5.1",
    "superjson": "^2.2.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@cloudflare/workers-types": "^4.20260213.0",
    "@expo/ngrok": "^4.1.3",
    "@hono/trpc-server": "^0.4.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/cookie": "^1.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.1.17",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "drizzle-kit": "1.0.0-beta.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "eslint-config-expo": "~10.0.0",
    "hono": "^4.11.9",
    "javascript-obfuscator": "^5.3.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "qrcode": "^1.5.4",
    "react-test-renderer": "^19.2.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.65.0"
  },
  "overrides": {
    "esbuild": ">=0.25.0",
    "js-yaml": ">=4.1.1",
    "qs": ">=6.14.1",
    "tar": ">=7.5.7",
    "undici": ">=6.23.0",
    "uuid": "^10.0.0",
    "rimraf": "^5.0.0",
    "glob": "^13.0.3",
    "inflight": "^1.0.6",
    "formdata-node": "6.0.3"
  }
}
