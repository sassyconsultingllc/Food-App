{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_BASE_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://privacy.sassyconsultingllc.com/foodie-finder",
        "EXPO_PUBLIC_TERMS_URL": "https://privacy.sassyconsultingllc.com/foodie-finder/terms"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_BASE_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://privacy.sassyconsultingllc.com/foodie-finder",
        "EXPO_PUBLIC_TERMS_URL": "https://privacy.sassyconsultingllc.com/foodie-finder/terms"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://privacy.sassyconsultingllc.com/foodie-finder",
        "EXPO_PUBLIC_TERMS_URL": "https://privacy.sassyconsultingllc.com/foodie-finder/terms"
      }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./keys/foodie-finder-482309-23769b0ab7f7.json",
        "track": "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "$APPLE_ID",
        "ascAppId": "$ASC_APP_ID",
        "appleTeamId": "$APPLE_TEAM_ID"
      }
    }
  }
}
