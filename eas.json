{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "development",
        "EXPO_PUBLIC_API_BASE_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_LICENSE_SERVER_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://sassyconsultingllc.com/privacy/foodie-finder/",
        "EXPO_PUBLIC_TERMS_URL": "https://sassyconsultingllc.com/privacy/foodie-finder/terms",
        "EXPO_PUBLIC_PAYWALL_MODE": "enforced",
        "EXPO_PUBLIC_ALLOW_TEST_KEYS": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "preview",
        "EXPO_PUBLIC_API_BASE_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_LICENSE_SERVER_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://sassyconsultingllc.com/privacy/foodie-finder/",
        "EXPO_PUBLIC_TERMS_URL": "https://sassyconsultingllc.com/privacy/foodie-finder/terms",
        "EXPO_PUBLIC_PAYWALL_MODE": "enforced",
        "EXPO_PUBLIC_ALLOW_TEST_KEYS": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "resourceClass": "m-medium"
      },
      "env": {
        "APP_ENV": "production",
        "EXPO_PUBLIC_API_BASE_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_LICENSE_SERVER_URL": "https://foodie-finder.sassyconsultingllc.com",
        "EXPO_PUBLIC_PRIVACY_POLICY_URL": "https://sassyconsultingllc.com/privacy/foodie-finder/",
        "EXPO_PUBLIC_TERMS_URL": "https://sassyconsultingllc.com/privacy/foodie-finder/terms",
        "EXPO_PUBLIC_PAYWALL_MODE": "enforced"
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./keys/foodie-finder-482309-b295a6ae77f9.json",
        "track": "internal",
        "releaseStatus": "completed",
        "changesNotSentForReview": true
      }
    },
    "beta": {
      "android": {
        "serviceAccountKeyPath": "./keys/foodie-finder-482309-b295a6ae77f9.json",
        "track": "beta",
        "releaseStatus": "completed"
      }
    },
    "production-staged": {
      "android": {
        "serviceAccountKeyPath": "./keys/foodie-finder-482309-b295a6ae77f9.json",
        "track": "production",
        "releaseStatus": "inProgress",
        "rollout": 0.1
      }
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./keys/foodie-finder-482309-b295a6ae77f9.json",
        "track": "production",
        "releaseStatus": "draft"
      },
      "ios": {
        "appleId": "$APPLE_ID",
        "ascAppId": "$ASC_APP_ID",
        "appleTeamId": "$APPLE_TEAM_ID"
      }
    }
  }
}
