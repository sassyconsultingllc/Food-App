# Foodie Finder Environment Configuration
# Copy this to .env and fill in your values

# =============================================================================
# RESTAURANT DATA SOURCES
# Configure at least one for restaurant data. More sources = better coverage.
# =============================================================================

# Foursquare Places API (100k calls/month free) - RECOMMENDED
# Get your key at: https://developer.foursquare.com/
FOURSQUARE_API_KEY=

# HERE Places API (250k calls/month free)
# Get your key at: https://developer.here.com/
HERE_API_KEY=

# Google Places API ($200/month free credit, then ~$17/1000 requests)
# Get your key at: https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=

# Google Cloud Vision API — SERVER-ONLY. Never expose this as
# EXPO_PUBLIC_* or it ships inside every installed APK and anyone can
# extract it. The worker proxies client requests via /api/vision/classify.
GOOGLE_VISION_API_KEY=

# Debug token — required to hit /api/debug/* endpoints in production.
# Leave unset to keep the debug routes completely disabled (they 404).
DEBUG_TOKEN=

# OpenStreetMap/Overpass - No key needed, always enabled
# Culver's API - No key needed, always enabled

# =============================================================================
# AI/LLM FOR SENTIMENT ANALYSIS (Optional but recommended)
# =============================================================================

# OpenAI API Key for sentiment analysis and RAG summaries
OPENAI_API_KEY=

# Optional CLIP endpoint for image embeddings
CLIP_API_URL=

# =============================================================================
# DATABASE
# =============================================================================

# MySQL connection string
DATABASE_URL=mysql://user:password@localhost:3306/foodie_finder

# =============================================================================
# PUBLIC LINKS (used in store listing and in-app links)
# =============================================================================
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://privacy.sassyconsultingllc.com/foodie-finder
EXPO_PUBLIC_TERMS_URL=https://privacy.sassyconsultingllc.com/foodie-finder/terms

# =============================================================================
# SERVER
# =============================================================================

PORT=3000
NODE_ENV=development

# =============================================================================
# REDIS & QUEUE (Optional - for background jobs)
# =============================================================================

REDIS_URL=redis://localhost:6379
PUSHGATEWAY_URL=http://localhost:9091

# ChromaDB for vector search
CHROMA_SERVER_URL=http://localhost:8000

# =============================================================================
# OAUTH (if using social login)
# =============================================================================

OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=
OAUTH_SERVER_URL=http://localhost:3000
# JWT secret is REQUIRED in production. Generate a long random string.
# Never leave this as "dev-secret" or any predictable value.
JWT_SECRET=

# =============================================================================
# APP IDENTITY (Required for server startup)
# =============================================================================

VITE_APP_ID=foodie-finder
OWNER_OPEN_ID=

# =============================================================================
# EXPO / EAS
# =============================================================================

# Expo port for development
EXPO_PORT=8081

# App Store URLs (required for submission)
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://privacy.sassyconsultingllc.com/foodie-finder
EXPO_PUBLIC_TERMS_URL=https://privacy.sassyconsultingllc.com/foodie-finder/terms

# =============================================================================
# LICENSE SERVER (Disabled in this build)
# =============================================================================

# EXPO_PUBLIC_LICENSE_SERVER_URL=https://license.yourdomain.com
# LICENSE_PRIVATE_KEY=
# LICENSE_ADMIN_SECRET=change-this-to-a-secure-random-string

# =============================================================================
# APP STORE SUBMISSION (set in EAS secrets or local env)
# =============================================================================

# Apple App Store Connect
APPLE_ID=your-apple-id@example.com
ASC_APP_ID=your-app-store-connect-app-id
APPLE_TEAM_ID=your-apple-team-id

# Google Play Console
# Place google-service-account.json in ./keys/ directory
